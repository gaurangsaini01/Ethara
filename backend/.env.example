# Local docker-compose uses the "db" service hostname.
# For Neon/Render, paste the connection string they give you (sslmode=require is handled automatically).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/inventory

# Comma-separated list of allowed frontend origins, or * to allow any.
CORS_ORIGINS=*

# Products at or below this quantity are flagged as low stock on the dashboard.
LOW_STOCK_THRESHOLD=10
